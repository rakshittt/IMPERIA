# LLM Provider: IMPERIA uses DeepSeek for AI synthesis and expert agents.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4
# IMPERIA treats deepseek-v4 as a product-level alias:
# fast mode resolves to deepseek-v4-flash; deep mode resolves to deepseek-v4-pro.
# Optional overrides. If unset, both fall back to DEEPSEEK_MODEL.
DEEPSEEK_FAST_MODEL=
DEEPSEEK_DEEP_MODEL=
DEEPSEEK_CALLS_PER_MINUTE=20
# disabled keeps JSON agent outputs reliable; set enabled only if you want v4 reasoning traces.
DEEPSEEK_THINKING=disabled
DEEPSEEK_FAST_ATTEMPTS=1
DEEPSEEK_DEEP_ATTEMPTS=1
DEEPSEEK_TIMEOUT_CONNECT=5
DEEPSEEK_FAST_TIMEOUT_READ=30
DEEPSEEK_DEEP_TIMEOUT_READ=60
# By default IMPERIA does not send max_tokens to DeepSeek and does not
# artificially truncate expert-agent evidence bundles. Enable only for
# constrained local/dev environments.
IMPERIA_DEEPSEEK_COMPACT_CONTEXT=false
# synthesis_only keeps API latency predictable; set all for expensive offline all-agent refinement.
IMPERIA_AGENT_LLM_REFINEMENT=synthesis_only

# Free US finance backend
# SEC asks automated clients to identify themselves. Override this with a real
# app/operator contact in production.
SEC_USER_AGENT=IMPERIA/0.3.0 contact=dev@example.com
TRADINGAGENTS_SQLITE_CACHE=
TRADINGAGENTS_API_RATE_LIMIT=120
TRADINGAGENTS_API_CACHE_TTL=15
IMPERIA_DEMO_MODE=false
IMPERIA_CACHE_BACKEND=sqlite
REDIS_URL=redis://localhost:6379
POLYMARKET_CACHE_TTL_SECONDS=300
GAMMA_API_BASE=https://gamma-api.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
FRED_API_KEY=
# API access control: set to a long random string to require X-API-Key header on
# admin and research-submission endpoints. Leave blank for open local/demo access.
IMPERIA_API_KEY=

# Optional free-tier data keys already supported by the project.
# The backend does not require paid market-data subscriptions.
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
TWELVE_DATA_API_KEY=
EODHD_API_KEY=
NEWSAPI_API_KEY=
NEWSDATA_API_KEY=
THENEWSAPI_COM_API_TOKEN=
THENEWSAPI_API_TOKEN=
TAVILY_API_KEY=
PERSISTENCE_DB_PATH=./.tradingagents_data/user_data.db
