            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticker\": \"AAPL\",\n  \"query\": \"What happened to Apple today?\",\n  \"window\": \"today\",\n  \"focus\": [\"fundamentals\", \"news\", \"earnings\"]\n}"
